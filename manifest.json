{
  "manifest_version": 3,
  "name": "NYT Crossword++",
  "version": "1.0",
  "description": "Pencil toggle, shift-to-rebus, and custom pencil color for the NYT Crossword.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.nytimes.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.nytimes.com/crosswords*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "NYT Crossword++ – click to open settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
